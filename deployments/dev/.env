RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_NOTIFY_MQTT_ENABLE_PRIMARY=true
RUSTFS_NOTIFY_MQTT_BROKER_PRIMARY=mqtt://nats:1883
RUSTFS_NOTIFY_MQTT_TOPIC_PRIMARY=safebucket-bucket-events
RUSTFS_NOTIFY_MQTT_QOS_PRIMARY=2
RUSTFS_NOTIFY_MQTT_QUEUE_DIR_PRIMARY=/data/.rustfs/events
POSTGRES_USER=safebucket-user
POSTGRES_PASSWORD=safebucket-password
POSTGRES_DB=safebucket
VALKEY_PASSWORD=root

# Activity Configuration
ACTIVITY__TYPE=filesystem
ACTIVITY__FILESYSTEM__DIRECTORY=./data/activity
# ACTIVITY__TYPE=loki
# ACTIVITY__LOKI__ENDPOINT=http://localhost:3100

COMPOSE_PROFILES=debug

# Profiling Configuration
APP__PROFILING__ENABLED=true
APP__PROFILING__TYPE=pyroscope
APP__PROFILING__PYROSCOPE__SERVER_ADDRESS=http://localhost:4040
APP__PROFILING__PYROSCOPE__APPLICATION_NAME=safebucket
APP__PROFILING__PYROSCOPE__UPLOAD_RATE=15

# Tracing Configuration
TRACING__ENABLED=true
TRACING__TYPE=tempo
TRACING__TEMPO__ENDPOINT=http://localhost:4318
TRACING__TEMPO__SERVICE_NAME=safebucket
TRACING__TEMPO__SAMPLING_RATE=1.0
